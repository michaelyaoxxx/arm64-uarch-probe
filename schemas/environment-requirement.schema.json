{
  "$id": "https://arm64-uarch-probe.dev/schemas/environment-requirement.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "capability_id": {"type": "string"},
    "id": {"type": "string"},
    "mutation": {"type": "boolean"},
    "requires_privilege": {"type": "boolean"},
    "scope": {"enum": ["host", "case"]},
    "values": {"additionalProperties": {"$ref": "#/$defs/scalar"}, "type": "object"}
  },
  "required": ["capability_id", "id", "mutation", "requires_privilege", "scope", "values"],
  "type": "object",
  "$defs": {
    "scalar": {"type": ["string", "integer", "number", "boolean", "null"]}
  }
}
