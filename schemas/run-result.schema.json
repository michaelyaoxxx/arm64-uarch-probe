{
  "$id": "https://arm64-uarch-probe.dev/schemas/run-result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "environment": {"type": "object"},
    "journal_transactions": {
      "description": "Transaction IDs of the EnvironmentJournal records written during this run, in execution order. Empty array when the runner did not invoke any host-mutating controller (e.g. all cases were 'skipped' or the platform has no mutation controllers).",
      "items": {
        "description": "32-hex lowercase transaction ID, matching EnvironmentJournal.transaction_id.",
        "pattern": "^[0-9a-f]{32}$",
        "type": "string"
      },
      "type": "array"
    },
    "plan": {"$ref": "plan.schema.json"},
    "prior_run_id": {"type": ["string", "null"]},
    "resume_kind": {"type": ["string", "null"]},
    "run_id": {"type": "string"},
    "samples": {"items": {"$ref": "sample.schema.json"}, "type": "array"},
    "schema_version": {"type": "integer"},
    "summary": {"type": "object"}
  },
  "required": ["environment", "plan", "run_id", "samples", "summary"],
  "type": "object"
}
